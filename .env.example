# ============================================================
#  AUDITORÍA DE SEGURIDAD - Variables de entorno
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas el .env a control de versiones.
# ============================================================

GEMINI_API_KEY=tu_api_key_aqui
SSH_HOST=192.168.1.100
SSH_USER=tu_usuario
SSH_KEY_PATH=/home/user/.ssh/id_ed25519
SSH_KNOWN_HOSTS_PATH=/home/user/.ssh/known_hosts  # Opcional

# Opcional: Mejora la detección de servicios (permite ver procesos)
SUDO_PASSWORD=tu_contraseña_sudo
